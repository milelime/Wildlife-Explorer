@startuml
!include ../include/diagram-style.puml

title Rate Existing Trail (0–10)

actor "End User" as EU
boundary TrailPanel
control TrailService
database Database

EU -> TrailPanel : open trail detail

TrailPanel -> TrailService : getTrail(trailId)
TrailService -> Database : fetchTrailById(trailId)
Database --> TrailService : trail
TrailService --> TrailPanel : trail

TrailPanel --> EU : show trail info

EU -> TrailPanel : click "Rate"
EU -> TrailPanel : click score button (0–10)

TrailPanel -> TrailService : rateTrail(trailId, score)
TrailService -> Database : insertRating(trailId, score)
Database -> Database : save()
Database --> TrailService : ok
TrailService --> TrailPanel : ok

TrailPanel --> EU : updated average rating shown

@enduml
