@startuml
!include include/diagram-style.puml

top to bottom direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam ranksep 70
skinparam nodesep 60
skinparam DefaultTextAlignment center

skinparam usecase {
  BackgroundColor white
  BorderColor black
}

skinparam rectangle {
  BackgroundColor white
  BorderColor black
}

' Primary actor: human operator
actor "End User" as EndUser

rectangle "Wildlife Explorer" {

  package "Use" {
    usecase "UC-01 — Search Trails" as UC_Search
    usecase "UC-02 — View Trail Information\n(trail, wildlife, images)" as UC_View
  }

  package "Contribute" {
    usecase "UC-03 — Add New Trail" as UC_AddTrail
    usecase "UC-04 — Rate Existing Trail\n(score 0–10)" as UC_RateTrail
    usecase "UC-05 — Edit Existing Trail Information" as UC_EditTrail
    usecase "UC-06 — Add Wildlife to Trail\n(new species or from catalog)" as UC_AddWildlife
    usecase "UC-07 — Remove Wildlife from Trail" as UC_RemoveWildlife
    usecase "UC-08 — Delete Trail" as UC_DeleteTrail
  }

  package "Required Trail Details" {
    usecase "UC-09 — Provide Trail Name" as UC_TrailName
    usecase "UC-10 — Provide Trail Length" as UC_TrailLength
    usecase "UC-11 — Provide Elevation Changes" as UC_Elevation
    usecase "UC-12 — Provide Trail Pictures\n(optional)" as UC_TrailPictures
  }

  package "Wildlife details\n(mainly when creating new species)" {
    usecase "UC-13 — Provide Wildlife Name" as UC_WildlifeName
    usecase "UC-14 — Provide Wildlife Description" as UC_WildlifeDesc
    usecase "UC-15 — Provide Encounter Notes" as UC_EncounterNotes
    usecase "UC-16 — Provide Wildlife Pictures\n(optional)" as UC_WildlifePictures
  }
}

EndUser --> UC_Search
EndUser --> UC_AddTrail
EndUser --> UC_RateTrail
EndUser --> UC_EditTrail
EndUser --> UC_AddWildlife
EndUser --> UC_RemoveWildlife
EndUser --> UC_DeleteTrail

UC_Search .[#1f77b4].> UC_View : <<include>>
UC_RateTrail .[#2ca02c].> UC_View : <<include>>
UC_EditTrail .[#d62728].> UC_View : <<include>>
UC_AddWildlife .[#9467bd].> UC_View : <<include>>
UC_RemoveWildlife .[#98df8a].> UC_View : <<include>>

UC_AddTrail .[#ff7f0e].> UC_TrailName : <<include>>
UC_AddTrail .[#bcbd22].> UC_TrailLength : <<include>>
UC_AddTrail .[#17becf].> UC_Elevation : <<include>>
UC_AddTrail .[#8c564b].> UC_TrailPictures : <<include>>

UC_AddWildlife .[#e377c2].> UC_WildlifeName : <<include>>
UC_AddWildlife .[#7f7f7f].> UC_WildlifeDesc : <<include>>
UC_AddWildlife .[#8c6d31].> UC_EncounterNotes : <<include>>
UC_AddWildlife .[#3182bd].> UC_WildlifePictures : <<include>>

note right of UC_AddWildlife
  End User may **attach an existing catalog species**
  instead of filling all wildlife detail fields (UC-13–UC-16).
end note

@enduml
