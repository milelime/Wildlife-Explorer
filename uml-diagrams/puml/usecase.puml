@startuml
!include include/diagram-style.puml

top to bottom direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam ranksep 70
skinparam nodesep 60
skinparam DefaultTextAlignment center

skinparam usecase {
  BackgroundColor white
  BorderColor black
}

skinparam rectangle {
  BackgroundColor white
  BorderColor black
}

actor User

rectangle "Wildlife Explorer" {

  package "Use" {
    usecase "Search Trails" as UC_Search
    usecase "View Trail Information\n(trail, wildlife, images)" as UC_View
  }

  package "Contribute" {
    usecase "Add New Trail" as UC_AddTrail
    usecase "Rate Existing Trail\n(score 0–10)" as UC_RateTrail
    usecase "Edit Existing Trail Information" as UC_EditTrail
    usecase "Add Wildlife to Trail\n(new species or from catalog)" as UC_AddWildlife
    usecase "Remove Wildlife from Trail" as UC_RemoveWildlife
  }

  package "Required Trail Details" {
    usecase "Provide Trail Name" as UC_TrailName
    usecase "Provide Trail Length" as UC_TrailLength
    usecase "Provide Elevation Changes" as UC_Elevation
    usecase "Provide Trail Pictures\n(optional)" as UC_TrailPictures
  }

  package "Wildlife details\n(mainly when creating new species)" {
    usecase "Provide Wildlife Name" as UC_WildlifeName
    usecase "Provide Wildlife Description" as UC_WildlifeDesc
    usecase "Provide Encounter Notes" as UC_EncounterNotes
    usecase "Provide Wildlife Pictures\n(optional)" as UC_WildlifePictures
  }
}

User --> UC_Search
User --> UC_AddTrail
User --> UC_RateTrail
User --> UC_EditTrail
User --> UC_AddWildlife
User --> UC_RemoveWildlife

UC_Search .[#1f77b4].> UC_View : <<include>>
UC_RateTrail .[#2ca02c].> UC_View : <<include>>
UC_EditTrail .[#d62728].> UC_View : <<include>>
UC_AddWildlife .[#9467bd].> UC_View : <<include>>
UC_RemoveWildlife .[#98df8a].> UC_View : <<include>>

UC_AddTrail .[#ff7f0e].> UC_TrailName : <<include>>
UC_AddTrail .[#bcbd22].> UC_TrailLength : <<include>>
UC_AddTrail .[#17becf].> UC_Elevation : <<include>>
UC_AddTrail .[#8c564b].> UC_TrailPictures : <<include>>

UC_AddWildlife .[#e377c2].> UC_WildlifeName : <<include>>
UC_AddWildlife .[#7f7f7f].> UC_WildlifeDesc : <<include>>
UC_AddWildlife .[#8c6d31].> UC_EncounterNotes : <<include>>
UC_AddWildlife .[#3182bd].> UC_WildlifePictures : <<include>>

note right of UC_AddWildlife
  User may **attach an existing catalog species**
  instead of filling all wildlife fields.
end note

@enduml
